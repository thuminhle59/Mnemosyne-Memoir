LLM_API_KEY=
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
STT_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/maas/user-111659/openai/whisper-large-v3/v1/audio/transcriptions
# Extraction tier (transcript -> report + facts). Safe default = minimax (verified).
SUMMARY_MODEL=minimax/minimax-m2.5
# EXTRACT_MODEL defaults to SUMMARY_MODEL; override to try gemini-2.5-flash etc.
# EXTRACT_MODEL=gemini/gemini-2.5-flash
# Heavy reasoning tier (Q&A / contradiction / digest). gemma won the A/B
# (same quality as qwen, far faster).
REASONING_MODEL=google/gemma-4-31b-it
# Per-tier fallbacks (only used when the primary errors/404s).
EXTRACT_FALLBACK_MODEL=google/gemma-4-31b-it
REASONING_FALLBACK_MODEL=qwen/qwen3-5-27b
STT_MODEL=openai/whisper-large-v3
# Memory store: SQLite local for demo; swap to Postgres via DATABASE_URL later.
DATABASE_URL=sqlite:///mnemosyne.db
# --- STT term correction (Whisper mishears proper nouns) ---
# Layer 2: regex fix of contest-name mishearings (CloudTown -> Claw-a-thon).
# Set false for unknown-topic audio to avoid false positives.
STT_FIX_TERMS=true
# Layer 3: context-aware LLM correction against a glossary (best for unknown topics).
STT_LLM_CORRECT=true
STT_CORRECT_MODEL=google/gemma-4-31b-it
STT_GLOSSARY=Claw-a-thon, GreenNode, ZaloPay, AgentBase, OpenClaw, Mnemosyne, Merchant, MCP Server, QA, UAT, API, Pilot, Canary, Settlement
# Audio chunk length (seconds) for STT of long recordings.
# STT_CHUNK_SEC=600
# Optional upload cap exposed to the web frontend. Default in code is 500 MB.
# MNEMOSYNE_MAX_UPLOAD_BYTES=524288000
# Optional browser upload chunk size. Default in code is 16 MB.
# MNEMOSYNE_UPLOAD_CHUNK_BYTES=16777216
# Optional staging path for chunked uploads.
# MNEMOSYNE_UPLOAD_STAGING_DIR=/tmp/mnemosyne_uploads
# Optional progress cache TTL for upload/ingest status.
# MNEMOSYNE_INGEST_PROGRESS_TTL_SEC=3600
# Optional: characters above which analysis switches from 1-pass to map-reduce
# MAP_REDUCE_CHAR_THRESHOLD=24000
# Optional email delivery (best-effort; the report file is always returned regardless)
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SSL=false   # true = implicit TLS (port 465); auto-on when SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=you@example.com
